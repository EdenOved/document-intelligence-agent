APP_NAME=document-intelligence-agent
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=document_intelligence
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/document_intelligence

OPENAI_API_KEY=
OPENAI_REASONING_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072

COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v4.0-fast

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=document-intelligence-agent

DEFAULT_TOP_K=12
DEFAULT_RERANK_TOP_N=6
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
MAX_AGENT_ITERATIONS=2

# Slack
SLACK_WEBHOOK_URL=
SLACK_DEFAULT_CHANNEL_NAME=

# Monday
MONDAY_API_TOKEN=
MONDAY_API_VERSION=2026-01
MONDAY_BOARD_ID=
MONDAY_GROUP_ID=
MONDAY_OWNER_COLUMN_ID=
MONDAY_DUE_DATE_COLUMN_ID=
MONDAY_PRIORITY_COLUMN_ID=
MONDAY_SOURCE_COLUMN_ID=
